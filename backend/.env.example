# Database Configuration
DATABASE_URL="postgresql://user:password@localhost:5432/digital_menu"

# Email Configuration (SMTP - Brevo)
SMTP_HOST="smtp-brevo.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-smtp-user@smtp-brevo.com"
SMTP_PASS="your-smtp-password"
SENDER_EMAIL="your-email@gmail.com"
SENDER_NAME="Your Restaurant Name"
REPLY_TO_EMAIL="your-email@gmail.com"

# Restaurant Configuration
RESTAURANT_NAME="Your Restaurant Name"

# JWT Configuration
JWT_SECRET="your-jwt-secret-key"
JWT_EXPIRES_IN="7d"

# Server Configuration
PORT=3001
